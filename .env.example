# ============================================================================
# NEXORA CLINIC SAAS - CONFIGURACIÓN DE ENTORNO
# ============================================================================

# ----------------------------------------------------------------------------
# BASE DE DATOS (REQUERIDO)
# ----------------------------------------------------------------------------
# PostgreSQL connection string
DATABASE_URL="postgresql://usuario:password@localhost:5432/nexora?schema=public"

# ----------------------------------------------------------------------------
# AUTENTICACIÓN Y SEGURIDAD (REQUERIDO)
# ----------------------------------------------------------------------------
# JWT Secret para tokens de autenticación (generar uno seguro en producción)
JWT_SECRET="tu-jwt-secret-seguro-aqui-minimo-32-caracteres"

# Google OAuth (opcional - para login con Google)
VITE_GOOGLE_CLIENT_ID="tu-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="tu-google-client-secret"

# ----------------------------------------------------------------------------
# INTELIGENCIA ARTIFICIAL (REQUERIDO PARA FUNCIONES IA)
# ----------------------------------------------------------------------------
# Gemini API Key de Google AI Studio - Obténla en https://aistudio.google.com
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# ----------------------------------------------------------------------------
# PAGOS Y FACTURACIÓN (REQUERIDO PARA SUSCRIPCIONES)
# ----------------------------------------------------------------------------
# Stripe Secret Key (modo test o live) - Ejemplo: sk_test_1234567890abcdef
STRIPE_SECRET_KEY="YOUR_STRIPE_SECRET_KEY_HERE"
# Stripe Webhook Secret - Ejemplo: whsec_1234567890abcdef
STRIPE_WEBHOOK_SECRET="YOUR_STRIPE_WEBHOOK_SECRET_HERE"
# Stripe Price IDs para cada plan
STRIPE_STARTER_PRICE_ID="price_YOUR_STARTER_PRICE_ID"
STRIPE_PRO_PRICE_ID="price_YOUR_PRO_PRICE_ID"
STRIPE_ELITE_PRICE_ID="price_YOUR_ELITE_PRICE_ID"

# ----------------------------------------------------------------------------
# COMUNICACIONES (OPCIONAL - PARA NOTIFICACIONES)
# ----------------------------------------------------------------------------
# Twilio - SMS y WhatsApp - Obténlas en https://twilio.com/console
TWILIO_ACCOUNT_SID="YOUR_TWILIO_ACCOUNT_SID_HERE"
TWILIO_AUTH_TOKEN="YOUR_TWILIO_AUTH_TOKEN_HERE"
TWILIO_PHONE_NUMBER="+34123456789"
TWILIO_WHATSAPP_NUMBER="+34123456789"

# Email SMTP (para notificaciones por email)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="notificaciones@tuclinica.com"
SMTP_PASS="tu-password-smtp"
FROM_EMAIL="Nexora <notificaciones@tuclinica.com"

# ----------------------------------------------------------------------------
# CONFIGURACIÓN GENERAL DE LA APLICACIÓN
# ----------------------------------------------------------------------------
# URL de la aplicación (usada para enlaces, OAuth, webhooks)
APP_URL="http://localhost:3000"

# Entorno: development | production
NODE_ENV="development"

# Puerto del servidor (default: 3000)
PORT="3000"

# ----------------------------------------------------------------------------
# DESARROLLO WEB (OPCIONAL - PARA SERVICIO DE WEBS)
# ----------------------------------------------------------------------------
# Email donde recibir solicitudes de desarrollo web
WEB_DEV_EMAIL="desarrollo@nexora.health"
# Notificar por email cuando llegue nueva solicitud (true/false)
NOTIFY_WEB_REQUESTS="true"

# ----------------------------------------------------------------------------
# OPCIONES AVANZADAS
# ----------------------------------------------------------------------------
# Habilitar modo demo sin base de datos (true/false)
ENABLE_DEMO_MODE="false"
# Log level: debug | info | warn | error
LOG_LEVEL="info"
