# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GOOGLE_GENAI_API_KEY="MY_GEMINI_API_KEY"

# JWT_SECRET: Secret key for JWT token signing
JWT_SECRET="change-me-in-production"

# VITE_GOOGLE_CLIENT_ID: Google OAuth client ID (for login)
VITE_GOOGLE_CLIENT_ID=""

# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# DATABASE_URL: Connection URL for the PostgreSQL database
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/clinicsaas?schema=public"
# For Supabase pooler (PgBouncer), use port 6543 and append ?pgbouncer=true:
# DATABASE_URL="postgresql://user:pass@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# STRIPE_SECRET_KEY: Stripe secret key for billing endpoints
STRIPE_SECRET_KEY="sk_test_123456789"

# Stripe price IDs for subscription plans (Starter / Pro / Premium)
STRIPE_PRICE_STARTER="price_starter_id"
STRIPE_PRICE_PRO="price_pro_id"
STRIPE_PRICE_PREMIUM="price_premium_id"

# STRIPE_WEBHOOK_SECRET: Stripe webhook signing secret
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
