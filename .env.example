# === REQUIRED ===

# JWT Secret - Generate with: openssl rand -base64 64
# MUST be set in production. No fallback is used.
JWT_SECRET="generate-a-real-secret-with-openssl-rand-base64-64"

# Database connection URL (PostgreSQL)
# Example: postgresql://user:pass@host:5432/clinicsaas?schema=public
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/clinicsaas?schema=public"
# When using Supabase pooler (port 6543), add ?pgbouncer=true:
# DATABASE_URL="postgresql://user:pass@host:6543/postgres?pgbouncer=true"
# Direct connection for Prisma Migrate (bypass PgBouncer if using connection pooler):
# DATABASE_URL_DIRECT="postgresql://johndoe:randompassword@localhost:5432/clinicsaas?schema=public"

# === AUTH & SECURITY ===

# CORS origin (which domains can access the API). Use "*" or a specific origin.
CORS_ORIGIN="*"

# Google OAuth client ID (for login with Google)
# Create at https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=""

# === GEMINI AI ===
# Required for AI features (clinical summaries, WhatsApp drafts, etc.)
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GOOGLE_GENAI_API_KEY="MY_GEMINI_API_KEY"

# === STRIPE (Pagos) ===

# Stripe secret key (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY="sk_test_123456789"

# Stripe price IDs for subscription plans (Starter / Pro / Premium)
STRIPE_PRICE_STARTER="price_starter_id"
STRIPE_PRICE_PRO="price_pro_id"
STRIPE_PRICE_PREMIUM="price_premium_id"

# Stripe webhook signing secret
# Configure webhook endpoint in Stripe Dashboard pointing to: {APP_URL}/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# === EMAIL (SMTP) ===
# Optional: if not configured, emails are logged to console in dev mode.
# Recommended providers: SendGrid, Resend, Mailgun, or your own SMTP server.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@nexora.com"

# === APP ===

# Public URL where this app is hosted. Used for reset links, OAuth callbacks, etc.
APP_URL="http://localhost:3000"

PORT="3000"

NODE_ENV="development"

# === SEED (Admin inicial) ===
# Only used for `npm run seed`. Creates superadmin and demo tenants.
# NEVER hardcode credentials in code — set them here in .env (gitignored).
SEED_ADMIN_EMAIL="admin@nexora.com"
SEED_ADMIN_PASSWORD="Admin123!"
SEED_ADMIN_NAME="Admin Nexora"
