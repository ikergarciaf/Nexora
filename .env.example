# ============================================
# NEXORA - SaaS de gestión para clínicas
# Configuración de producción
# ============================================

# === REQUIRED (must be set) ===

# JWT Secret - Generate with: openssl rand -base64 64
# MUST be a strong, unique secret in production
JWT_SECRET="change-this-to-a-real-secret-openssl-rand-base64-64-chars-min"

# Database connection URL (PostgreSQL / Supabase)
# Supabase: postgresql://user:pass@host:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/clinicsaas?schema=public"

# === AUTH & SECURITY ===

# CORS origin (comma-separated for multiple origins)
CORS_ORIGIN="http://localhost:3000"

# Google OAuth client ID (for login with Google)
VITE_GOOGLE_CLIENT_ID=""

# === GEMINI AI ===
GEMINI_API_KEY=""
GOOGLE_GENAI_API_KEY=""

# === STRIPE (Pagos) ===
STRIPE_SECRET_KEY="sk_test_"
STRIPE_PRICE_STARTER="price_starter_id"
STRIPE_PRICE_PRO="price_pro_id"
STRIPE_PRICE_PREMIUM="price_premium_id"
STRIPE_WEBHOOK_SECRET="whsec_"

# === EMAIL (SMTP) ===
# Recommended: SendGrid, Resend, Mailgun, or your SMTP server
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@nexora.com"

# === APP ===
APP_URL="http://localhost:3000"
PORT="3000"
NODE_ENV="development"
LOG_LEVEL="debug"

# === CRON / Background Jobs ===
CRON_API_KEY="generate-a-random-api-key-here"

# === SEED (Admin inicial) ===
SEED_ADMIN_EMAIL="admin@nexora.com"
SEED_ADMIN_PASSWORD="Admin123!"
SEED_ADMIN_NAME="Admin Nexora"
