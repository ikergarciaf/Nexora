generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider      = "postgresql"
  url           = env("DATABASE_URL")
  relationMode  = "prisma"
}

model Tenant {
  id                   String        @id @default(uuid())
  name                 String
  slug                 String?       @unique
  taxId                String?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  subscriptionStatus   String        @default("trialing")
  subscriptionPlan     String        @default("STARTER")
  trialEndsAt          DateTime?
  
  // Customization fields
  logoUrl              String?
  address              String?
  ownerName            String?
  specialty            String        @default("Fisioterapia")
  description          String?
  themeColor           String?       @default("#008477")
  contactPhone         String?
  contactEmail         String?

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  appointments         Appointment[]
  invoices             Invoice[]
  patients             Patient[]
  treatments           Treatment[]
  memberships          TenantUser[]
  rooms                Room[]
  shifts               Shift[]
  consents             Consent[]
}

model User {
  id                  String        @id @default(uuid())
  email               String        @unique
  passwordHash        String?
  googleId            String?
  name                String
  isActive            Boolean       @default(true)
  isSuperAdmin        Boolean       @default(false)
  resetToken          String?       @unique
  resetTokenExpiresAt DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  memberships         TenantUser[]
  shifts              Shift[]
}

model TenantUser {
  id       String @id @default(uuid())
  userId   String
  tenantId String
  role     String @default("OWNER") // OWNER, STAFF
  
  user     User   @relation(fields: [userId], references: [id])
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([userId, tenantId])
}

model Patient {
  id                  String        @id @default(uuid())
  tenantId            String
  fullName            String
  dob                 DateTime?
  phone               String?
  email               String?
  medicalHistoryNotes String?
  tags                String?
  aiSummary           String?
  cachedAt            DateTime?
  lastVisit           DateTime?
  nutritionalPlan      String?       @default("{}")
  medicalRecord        String?       @default("{}")
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  appointments        Appointment[]
  invoices            Invoice[]
  consents            Consent[]
  tenant              Tenant        @relation(fields: [tenantId], references: [id])

  @@unique([id, tenantId])
}

model Appointment {
  id              String   @id @default(uuid())
  tenantId        String
  patientId       String
  doctorId        String?
  startTime       DateTime
  endTime         DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  type            String?
  status          String   @default("SCHEDULED")
  treatmentId     String?
  aiConflictScore Float?
  aiAlertReason   String?
  whatsappDraft   String?
  internalNotes   String?
  patient         Patient     @relation(fields: [patientId], references: [id])
  treatment       Treatment?  @relation(fields: [treatmentId], references: [id])
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  
  @@unique([id, tenantId])
}

model Treatment {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  category    String   @default("General")
  duration    Int      @default(30)
  price       Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  appointments Appointment[]

  @@unique([id, tenantId])
}

model Invoice {
  id          String        @id @default(uuid())
  tenantId    String
  patientId   String
  number      String?
  amount      Float
  currency    String        @default("EUR")
  status      String        @default("PENDING")
  description String?
  dueDate     DateTime?
  issuedDate  DateTime      @default(now())
  paidAt      DateTime?
  stripeInvoiceId String?
  patient     Patient       @relation(fields: [patientId], references: [id])
  tenant      Tenant        @relation(fields: [tenantId], references: [id])

  @@unique([id, tenantId])
}

model Room {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  shifts    Shift[]

  @@unique([id, tenantId])
}

model Shift {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  roomId    String?
  startTime DateTime
  endTime   DateTime
  type      String   @default("WORK") // WORK, VACATION, SICK_LEAVE
  notes     String?
  user      User     @relation(fields: [userId], references: [id])
  room      Room?    @relation(fields: [roomId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([id, tenantId])
}

model Consent {
  id              String    @id @default(uuid())
  tenantId        String
  patientId       String
  title           String
  content         String
  signatureDataUrl String?
  signedAt        DateTime?
  status          String    @default("draft") // draft, signed, revoked
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  patient         Patient   @relation(fields: [patientId], references: [id])
  tenant          Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([id, tenantId])
}
