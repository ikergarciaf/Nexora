generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Tenant {
  id                   String        @id @default(uuid())
  name                 String
  slug                 String?       @unique
  taxId                String?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  subscriptionStatus   String        @default("trialing")
  subscriptionPlan     String        @default("STARTER")
  trialEndsAt          DateTime?
  
  // Customization fields
  logoUrl              String?
  address              String?
  ownerName            String?
  specialty            String        @default("Fisioterapia")
  description          String?
  themeColor           String?       @default("#008477")
  contactPhone         String?
  contactEmail         String?

  createdAt            DateTime      @default(now())
  appointments         Appointment[]
  invoices             Invoice[]
  patients             Patient[]
  memberships          TenantUser[]
  rooms                Room[]
  shifts               Shift[]
  webDevRequests       WebDevelopmentRequest[]
  smsNotifications     SMSNotification[]
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String?
  googleId     String?
  name         String
  isActive     Boolean       @default(true)
  isSuperAdmin Boolean       @default(false)
  memberships  TenantUser[]
  shifts       Shift[]
}

model TenantUser {
  id       String @id @default(uuid())
  userId   String
  tenantId String
  role     String @default("OWNER") // OWNER, STAFF
  
  user     User   @relation(fields: [userId], references: [id])
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([userId, tenantId])
}

model Patient {
  id                  String        @id @default(uuid())
  tenantId            String
  fullName            String
  dob                 DateTime?
  phone               String?
  email               String?
  medicalHistoryNotes String?
  tags                String?
  aiSummary           String?
  cachedAt            DateTime?
  lastVisit           DateTime?
  exercises           Json?         @default("[]")
  nutritionalPlan     Json?         @default("{}")
  medicalRecord       Json?         @default("{}")
  appointments        Appointment[]
  invoices            Invoice[]
  smsNotifications    SMSNotification[]
  notificationPrefs   PatientNotificationPrefs?
  tenant              Tenant        @relation(fields: [tenantId], references: [id])

  @@unique([id, tenantId])
}

model Appointment {
  id              String   @id @default(uuid())
  tenantId        String
  patientId       String
  doctorId        String?
  startTime       DateTime
  endTime         DateTime
  type            String?
  status          String   @default("SCHEDULED")
  aiConflictScore Float?
  aiAlertReason   String?
  whatsappDraft   String?
  internalNotes   String?
  patient         Patient  @relation(fields: [patientId], references: [id])
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  
  @@unique([id, tenantId])
}

model Invoice {
  id         String   @id @default(uuid())
  tenantId   String
  patientId  String
  amount     Float
  currency   String   @default("USD")
  status     String   @default("PENDING")
  issuedDate DateTime @default(now())
  patient    Patient  @relation(fields: [patientId], references: [id])
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([id, tenantId])
}

model Room {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  shifts    Shift[]

  @@unique([id, tenantId])
}

model Shift {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  roomId    String?
  startTime DateTime
  endTime   DateTime
  type      String   @default("WORK") // WORK, VACATION, SICK_LEAVE
  notes     String?
  user      User     @relation(fields: [userId], references: [id])
  room      Room?    @relation(fields: [roomId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([id, tenantId])
}

// Solicitudes de desarrollo web para clínicas
model WebDevelopmentRequest {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  // Información de contacto
  contactName     String
  contactEmail    String
  contactPhone    String?

  // Detalles del proyecto
  projectType     String   @default("CLINIC_WEB") // CLINIC_WEB, REDESIGN, LANDING, ECOMMERCE
  currentWebsite  String?
  desiredFeatures String[] // Array de características solicitadas
  budgetRange     String?  // Ej: "599", "1000-2000", "2000+"

  // Estado de la solicitud
  status          String   @default("PENDING") // PENDING, REVIEWING, IN_PROGRESS, COMPLETED, CANCELLED
  priority        String   @default("NORMAL") // LOW, NORMAL, HIGH, URGENT

  // Notas y seguimiento
  notes           String?
  adminNotes      String?

  // Fechas importantes
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime?

  // Presupuesto y facturación
  quotedPrice     Float?
  finalPrice      Float?
  invoiceId       String?

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
}

// Notificaciones SMS enviadas a pacientes
model SMSNotification {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  // Destinatario
  patientId   String?
  patient     Patient? @relation(fields: [patientId], references: [id])
  phoneNumber String

  // Contenido del mensaje
  message     String
  type        String   @default("APPOINTMENT_REMINDER") // APPOINTMENT_REMINDER, CONFIRMATION, CANCELLATION, PROMOTION, CUSTOM

  // Estado del envío
  status      String   @default("PENDING") // PENDING, SENT, DELIVERED, FAILED
  provider    String   @default("twilio") // twilio, vonage, etc.
  providerId  String?  // ID del mensaje en el proveedor

  // Metadatos del envío
  sentAt      DateTime?
  deliveredAt DateTime?
  failedAt    DateTime?
  errorMessage String?

  // Relación con cita (opcional)
  appointmentId String?

  // Costo (para tracking)
  cost        Float?
  currency    String   @default("EUR")

  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([patientId])
  @@index([status])
  @@index([createdAt])
}

// Preferencias de notificación por paciente
model PatientNotificationPrefs {
  id            String   @id @default(uuid())
  patientId     String   @unique
  patient       Patient  @relation(fields: [patientId], references: [id])

  // Canales de comunicación
  emailEnabled  Boolean  @default(true)
  smsEnabled    Boolean  @default(true)
  whatsappEnabled Boolean @default(false)

  // Tipos de notificaciones
  appointmentReminders Boolean @default(true)
  confirmations   Boolean  @default(true)
  cancellations   Boolean  @default(true)
  marketing       Boolean  @default(false)

  // Horario preferido para contacto
  preferredContactTime String? // "MORNING", "AFTERNOON", "EVENING"

  updatedAt       DateTime @updatedAt

  @@index([patientId])
}
