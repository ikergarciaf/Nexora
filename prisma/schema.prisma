generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider      = "postgresql"
  url           = env("DATABASE_URL")
  directUrl     = env("DATABASE_URL_DIRECT")
  relationMode  = "prisma"
}

model Tenant {
  id                   String        @id @default(uuid())
  name                 String
  slug                 String        @unique
  taxId                String?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  subscriptionStatus   String        @default("trialing")
  subscriptionPlan     String        @default("STARTER")
  trialEndsAt          DateTime?
  
  // Customization fields
  logoUrl              String?
  address              String?
  ownerName            String?
  specialty            String        @default("Fisioterapia")
  description          String?
  themeColor           String?       @default("#008477")
  contactPhone         String?
  contactEmail         String?
  publicBookingEnabled Boolean       @default(false)
  locale               String        @default("es")

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  appointments         Appointment[]
  invoices             Invoice[]
  patients             Patient[]
  treatments           Treatment[]
  memberships          TenantUser[]
  rooms                Room[]
  shifts               Shift[]
  consents             Consent[]
  inventoryItems       InventoryItem[]
  campaigns            Campaign[]
  pushSubscriptions    PushSubscription[]
}

model User {
  id                  String        @id @default(uuid())
  email               String        @unique
  passwordHash        String?
  googleId            String?
  name                String
  isActive            Boolean       @default(true)
  isSuperAdmin        Boolean       @default(false)
  resetToken          String?       @unique
  resetTokenExpiresAt DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  memberships         TenantUser[]
  shifts              Shift[]
  createdPatients     Patient[]
  createdTreatments   Treatment[]
  createdInvoices     Invoice[]
}

model TenantUser {
  id       String @id @default(uuid())
  userId   String
  tenantId String
  role     String @default("OWNER") // OWNER, STAFF
  
  user     User   @relation(fields: [userId], references: [id])
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([userId, tenantId])
}

model Patient {
  id                  String        @id @default(uuid())
  tenantId            String
  fullName            String
  dob                 DateTime?
  phone               String?
  email               String?
  medicalHistoryNotes String?
  tags                String?
  aiSummary           String?
  cachedAt            DateTime?
  lastVisit           DateTime?
  nutritionalPlan      String?       @default("{}")
  medicalRecord        String?       @default("{}")
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  createdById         String?
  createdBy           User?         @relation(fields: [createdById], references: [id])
  appointments        Appointment[]
  invoices            Invoice[]
  consents            Consent[]
  tenant              Tenant        @relation(fields: [tenantId], references: [id])

  @@unique([id, tenantId])
  @@index([email])
}

model Appointment {
  id              String   @id @default(uuid())
  tenantId        String
  patientId       String
  doctorId        String?
  startTime       DateTime
  endTime         DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  type            String?
  status          String   @default("SCHEDULED")
  treatmentId     String?
  aiConflictScore Float?
  aiAlertReason   String?
  whatsappDraft   String?
  internalNotes   String?
  patient         Patient     @relation(fields: [patientId], references: [id])
  treatment       Treatment?  @relation(fields: [treatmentId], references: [id])
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  
  @@unique([id, tenantId])
  @@index([startTime])
  @@index([status])
  @@index([patientId])
}

model Treatment {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  category    String   @default("General")
  duration    Int      @default(30)
  price       Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  appointments Appointment[]

  @@unique([id, tenantId])
}

model Invoice {
  id          String        @id @default(uuid())
  tenantId    String
  patientId   String
  number      String?
  amount      Float
  currency    String        @default("EUR")
  status      String        @default("PENDING")
  description String?
  serviceDate DateTime?
  dueDate     DateTime?
  issuedDate  DateTime      @default(now())
  paidAt      DateTime?
  stripeInvoiceId String?
  createdById String?
  createdBy   User?         @relation(fields: [createdById], references: [id])
  patient     Patient       @relation(fields: [patientId], references: [id])
  tenant      Tenant        @relation(fields: [tenantId], references: [id])

  @@unique([id, tenantId])
  @@index([status])
  @@index([issuedDate])
}

model Room {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  shifts    Shift[]

  @@unique([id, tenantId])
}

model Shift {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  roomId    String?
  startTime DateTime
  endTime   DateTime
  type      String   @default("WORK") // WORK, VACATION, SICK_LEAVE
  notes     String?
  user      User     @relation(fields: [userId], references: [id])
  room      Room?    @relation(fields: [roomId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([id, tenantId])
}

model Consent {
  id              String    @id @default(uuid())
  tenantId        String
  patientId       String
  title           String
  content         String
  signatureDataUrl String?
  signedAt        DateTime?
  status          String    @default("draft") // draft, signed, revoked
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  patient         Patient   @relation(fields: [patientId], references: [id])
  tenant          Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([id, tenantId])
}

model InventoryItem {
  id            String   @id @default(uuid())
  tenantId      String
  name          String
  description   String?
  category      String   @default("General")
  quantity      Int      @default(0)
  minStock      Int      @default(5)
  price         Float    @default(0)
  supplier      String?
  batch         String?
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([id, tenantId])
  @@index([category])
  @@index([expiresAt])
}

model Campaign {
  id         String    @id @default(uuid())
  tenantId   String
  name       String
  subject    String
  body       String
  segment    String    @default("ALL")
  status     String    @default("DRAFT")
  sentAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  tenant     Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([id, tenantId])
}

model PushSubscription {
  id        String   @id @default(uuid())
  tenantId  String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([id, tenantId])
}
